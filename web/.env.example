# Supabase (required for booking + referral API routes)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: recommended for inserts from API routes (bypasses RLS safely)
# Create in Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
