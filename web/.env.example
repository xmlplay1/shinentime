# Supabase (required for booking + referral API routes)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Client-safe: legacy anon JWT OR modern publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only for /api/jobs + admin: legacy service_role JWT OR modern secret key (sb_secret_...)
# Put the secret in SUPABASE_SERVICE_ROLE_KEY — supabase-js accepts both formats.
SUPABASE_SERVICE_ROLE_KEY=

# Gmail SMTP (server-side emails for quote receipts + admin notifications)
GMAIL_USER=your-company@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password
EMAIL_FROM_NAME=Shine N Time
ADMIN_NOTIFICATION_EMAIL=tawfiqalshara424@gmail.com
REVIEW_REQUEST_URL=https://www.google.com/search?q=Shine+N+Time+detailing+reviews

# Admin dashboard gate (temporary until full auth is added)
ADMIN_PASSWORD=change_me_admin_password
